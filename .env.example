# Origami Engine — environment variables
# Copy to .env, fill in values, never commit .env to git

# Required
ANTHROPIC_API_KEY=sk-ant-...

# CAN-SPAM required fields (outreach liability)
SENDER_NAME=Script Master Labs LLC
SENDER_ADDRESS=123 Main St, Kinston NC 28501
OPTOUT_URL=https://scriptmasterlabs.com/unsubscribe

# Optional overrides
ORIGAMI_DB=origami.db          # default: origami.db in working dir
ORIGAMI_ICP=icp.json           # default: icp.json in working dir
ORIGAMI_VALUE_PROP=x402 lets autonomous agents pay per-call for MCP tools — no subscriptions, no API keys, no human in the loop.
